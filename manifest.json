{
    "manifest_version": 3,
    "name": "Youtube Tracker",
    "description": "You control Youtube and not the algorithm controls you!!",
    "version": "1.0",
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://*.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "popup.css"
            ]
        }
    ],
    "action": {
        "default_title": "YouTube Tracker",
        "default_popup": "extension.html",
        "default_icon": {
            "16": "extension.png",
            "48": "extension.png",
            "128": "extension.png"
        }
    },
    "icons": {
        "16": "extension.png",
        "48": "extension.png",
        "128": "extension.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "extension.png",
                "urvi.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}